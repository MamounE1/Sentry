# TEMPLATE FILE: Copy this to application.yaml and provide your own values
spring:
  application:
    name: Sentry
  datasource:
    url: jdbc:postgresql://your-db-url-here:6543/postgres?prepareThreshold=0
    username: your-username-here
    password: ${SENTRY_DB_PASSWORD} # Set this as a user environment variable
    driver-class-name: org.postgresql.Driver
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true

# JWT signing secret (must be at least 32 bytes for HS256). Set JWT_SECRET as an env var.
jwt:
  secret: ${JWT_SECRET:dev-only-secret-change-me-at-least-32-bytes-long-000}
  expiration-ms: ${JWT_EXPIRATION_MS:86400000} # token lifetime in ms (default 24h)

# Origins allowed to call the API from a browser (comma-separated). Set to your frontend URL.
app:
  cors:
    allowed-origins: ${APP_CORS_ALLOWED_ORIGINS:http://localhost:5173}