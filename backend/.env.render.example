# =============================================================================
# Render environment variables for the Sentry backend
# -----------------------------------------------------------------------------
# application.yaml is gitignored, so it does NOT exist on Render. Spring Boot
# reads these env vars directly via relaxed binding (SPRING_DATASOURCE_URL ->
# spring.datasource.url, etc.), so no config file is needed in production.
#
# In Render: Service -> Environment -> "Add from .env" and paste your filled-in
# copy of this file (with the real password). Do NOT commit the filled version.
# =============================================================================

# Supabase transaction pooler (port 6543). prepareThreshold=0 is required for
# the pooler. Copy the exact URL/username from your local application.yaml.
SPRING_DATASOURCE_URL=jdbc:postgresql://<your-supabase-pooler-host>:6543/postgres?prepareThreshold=0
SPRING_DATASOURCE_USERNAME=<your-supabase-username>
SPRING_DATASOURCE_PASSWORD=<your-supabase-db-password>

# Let Hibernate create/update tables on startup (matches your local config)
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Secret used to sign JWT auth tokens. REQUIRED in production (no default in code).
# Must be at least 32 bytes. Generate one, e.g.:  openssl rand -base64 48
JWT_SECRET=<generate-a-long-random-secret>

# (optional) token lifetime in milliseconds; defaults to 24h if unset
# JWT_EXPIRATION_MS=86400000

# Browser origin(s) allowed to call the API (comma-separated). Set this to your
# deployed frontend URL, e.g. https://sentry-frontend.onrender.com
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
